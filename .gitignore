# Dependencies - ignore node_modules in all directories
**/node_modules/

# Build outputs
*/.next/
*/out/
*/build/
*/*/.next/
*/*/out/
*/*/build/

# Environment files - don't commit secrets
*/*.env
*/*.env.local
*/*.env.*.local
!*/*.env.example

# Package lock files (optional - uncomment if you want to ignore)
# */package-lock.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Firebase
.firebase/
firebase-debug.log
firebase-debug.*.log

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Misc
*.pem
